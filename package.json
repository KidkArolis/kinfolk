{
  "name": "kinfolk",
  "version": "0.7.4",
  "description": "Atoms and selectors for React",
  "main": "dist/cjs/kinfolk.cjs",
  "module": "dist/esm/kinfolk.mjs",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "npm run lint && ava",
    "lint": "oxlint && oxfmt --check '**/*.js'",
    "format": "oxfmt --write '**/*.js'",
    "coverage": "nyc --reporter html ava",
    "build": "node ./build.js",
    "watch": "node ./build.js -w"
  },
  "author": "Karolis Narkevicius <hey@k8.lt>",
  "license": "ISC",
  "devDependencies": {
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.24",
    "@testing-library/react": "^16.3.2",
    "ava": "^7.0.0",
    "execa": "^9.6.1",
    "jsdom": "^29.0.2",
    "nyc": "^18.0.0",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "pirates": "^4.0.7"
  },
  "ava": {
    "files": [
      "test/*.test.js"
    ],
    "require": [
      "./test/register.js"
    ]
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "require": "./dist/cjs/kinfolk.cjs",
      "import": "./dist/esm/kinfolk.mjs"
    }
  }
}
